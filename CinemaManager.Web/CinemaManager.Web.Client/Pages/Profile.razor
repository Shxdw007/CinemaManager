@page "/profile"
@inject IJSRuntime JS
@inject ApiService Api

<PageTitle>Личный кабинет - Звездный</PageTitle>

@if (!isLoggedIn)
{
    <div class="cm-auth-wrap">
        <div class="cm-login-container">
            <div class="cm-logo" style="margin-bottom:30px">ЗВЕЗДНЫЙ ✦</div>

            <div class="cm-input-group">
                <label for="email">E-mail</label>
                <input id="email" class="cm-input" type="email" placeholder="example@mail.ru" @bind="email" />
            </div>

            <div class="cm-input-group">
                <label for="password">Пароль</label>
                <input id="password" class="cm-input" type="password" placeholder="••••••••" @bind="password" />
            </div>

            <button class="cm-btn" type="button" @onclick="Login">
                Войти в систему
            </button>

            <div class="cm-muted" style="margin-top:18px; font-size:14px">
                Нет аккаунта?
                <button type="button" class="cm-btn-secondary" style="margin-left:8px" @onclick="Register">
                    Зарегистрироваться
                </button>
            </div>

            @if (authMessage is not null)
            {
                <div class="cm-alert" style="margin-top:16px; text-align:left">
                    <strong>@authMessage</strong>
                </div>
            }

            <div class="cm-muted" style="margin-top:16px; font-size:12px; text-align:left">
                Демонстрационный режим: авторизация пока локальная (без API).
            </div>
        </div>
    </div>
}
else
{
    <div class="cm-profile-container">
        <div class="cm-profile-header">
            <div class="cm-avatar">@userInitial</div>
            <div class="cm-user-info">
                <h2>@fullName</h2>
                <p>@email • @phone</p>
            </div>
            <button type="button" class="cm-logout-btn" @onclick="Logout">Выйти</button>
        </div>

        <div class="cm-tabs">
            <button type="button" class="cm-tab @(activeTab is Tab.Active ? "active" : "")" @onclick="() => activeTab = Tab.Active">
                Мои билеты (@myTickets.Count)
            </button>
            <button type="button" class="cm-tab @(activeTab is Tab.History ? "active" : "")" @onclick="() => activeTab = Tab.History">
                История покупок
            </button>
        </div>

        @if (_ticketsLoading)
        {
            <div class="cm-alert"><strong>Загрузка билетов…</strong></div>
        }
        else if (_ticketsError is not null)
        {
            <div class="cm-alert">
                <strong>Не удалось загрузить билеты.</strong>
                <div class="cm-muted">@_ticketsError</div>
            </div>
        }
        else if (myTickets.Count == 0)
        {
            <div class="cm-alert">
                <strong>Вы еще не купили ни одного билета.</strong>
                <div class="cm-muted">Выберите сеанс и купите билет — он появится здесь автоматически.</div>
            </div>
        }
        else
        {
            @foreach (var t in myTickets)
            {
                <div class="cm-ticket">
                    <div class="cm-ticket-poster">Постер</div>
                    <div class="cm-ticket-details">
                        <h3>@t.MovieTitle</h3>
                        <p style="margin:0; color:#aaa">@t.HallName • Формат @t.HallType</p>

                        <div class="cm-ticket-meta">
                            <div class="cm-meta-item"><span>Дата</span><strong>@t.SessionStartTime.ToString("dd.MM.yyyy")</strong></div>
                            <div class="cm-meta-item"><span>Время</span><strong>@t.SessionStartTime.ToString("HH:mm")</strong></div>
                            <div class="cm-meta-item"><span>Ряд</span><strong>@t.Row</strong></div>
                            <div class="cm-meta-item"><span>Место</span><strong>@t.Seat</strong></div>
                        </div>

                        <p style="margin: 15px 0 0 0; font-size: 12px; color: #FFD700;">
                            ✦ Куплено: @t.PurchaseDate.ToLocalTime().ToString("dd.MM.yyyy HH:mm") • Цена: @t.TicketPrice ₽
                        </p>
                    </div>

                    <div class="cm-ticket-qr">
                        <div class="cm-qr-placeholder" aria-hidden="true">
                            @foreach (var dot in DemoQrMask(t.TicketId))
                            {
                                <div class="cm-qr-dot" style="@(dot ? "" : "background:transparent")"></div>
                            }
                        </div>
                        <div class="cm-ticket-status">Оплачен</div>
                    </div>
                </div>
            }
        }
    </div>
}

@code {
    private bool isLoggedIn = false;

    private string email = "ivanov@example.com";
    private string password = "password123";
    private string? authMessage;

    private readonly string fullName = "Иванов Иван";
    private readonly string phone = "+7 (999) 123-45-67";
    private string userInitial => string.IsNullOrWhiteSpace(fullName) ? "?" : fullName.Trim()[0].ToString();

    private Tab activeTab = Tab.Active;

    private bool _ticketsLoading;
    private string? _ticketsError;
    private List<MyTicketDto> myTickets = [];

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var saved = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey.LoggedIn);
            if (string.Equals(saved, "1", StringComparison.Ordinal))
            {
                var savedEmail = await JS.InvokeAsync<string?>("localStorage.getItem", StorageKey.Email);
                if (!string.IsNullOrWhiteSpace(savedEmail))
                    email = savedEmail;

                isLoggedIn = true;
                await LoadMyTicketsAsync();
            }
        }
        catch
        {
            // ignore: localStorage may be unavailable in some hosting scenarios
        }
    }

    private async Task Login()
    {
        authMessage = null;
        if (string.IsNullOrWhiteSpace(email) || string.IsNullOrWhiteSpace(password))
        {
            authMessage = "Заполните E-mail и пароль.";
            return;
        }

        isLoggedIn = true;
        password = "";

        try
        {
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey.LoggedIn, "1");
            await JS.InvokeVoidAsync("localStorage.setItem", StorageKey.Email, email);
        }
        catch
        {
            // ignore
        }

        await LoadMyTicketsAsync();
    }

    private void Register()
    {
        authMessage = "Регистрация будет подключена позже. Для демо нажмите «Войти в систему».";
    }

    private async Task Logout()
    {
        isLoggedIn = false;
        password = "";
        authMessage = null;
        activeTab = Tab.Active;
        myTickets = [];
        _ticketsError = null;
        _ticketsLoading = false;

        try
        {
            await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey.LoggedIn);
            await JS.InvokeVoidAsync("localStorage.removeItem", StorageKey.Email);
        }
        catch
        {
            // ignore
        }
    }

    private enum Tab
    {
        Active,
        History
    }

    private static class StorageKey
    {
        public const string LoggedIn = "cm.profile.loggedIn";
        public const string Email = "cm.profile.email";
    }

    private async Task LoadMyTicketsAsync()
    {
        _ticketsLoading = true;
        _ticketsError = null;
        myTickets = [];

        try
        {
            myTickets = (await Api.GetMyTicketsAsync(email)).ToList();
        }
        catch (Exception ex)
        {
            _ticketsError = ex.Message;
        }
        finally
        {
            _ticketsLoading = false;
        }
    }

    private static bool[] DemoQrMask(int seed)
    {
        var rng = new Random(seed);
        var mask = new bool[16];
        for (var i = 0; i < mask.Length; i++)
            mask[i] = rng.NextDouble() > 0.35;
        return mask;
    }
}
