@page "/"

@inject ApiService Api

<PageTitle>Афиша - Звездный</PageTitle>

<div class="cm-hero">
    <h1>Смотри на большом экране</h1>
    <div class="cm-filters">
        <button class="@GetFilterBtnCss(FilterKey.All)" type="button" @onclick="() => SetFilter(FilterKey.All)">В прокате</button>
        <button class="@GetFilterBtnCss(FilterKey.Soon)" type="button" @onclick="() => SetFilter(FilterKey.Soon)">Скоро</button>
        <button class="@GetFilterBtnCss(FilterKey.Fantasy)" type="button" @onclick="() => SetFilter(FilterKey.Fantasy)">Фантастика</button>
        <button class="@GetFilterBtnCss(FilterKey.Action)" type="button" @onclick="() => SetFilter(FilterKey.Action)">Боевики</button>
    </div>
</div>

@if (_isLoading)
{
    <div class="cm-loading">Загрузка фильмов…</div>
}
else if (_errorMessage is not null)
{
    <div class="cm-container">
        <div class="cm-alert">
            <div><strong>Не удалось загрузить фильмы.</strong></div>
            <div class="cm-muted">@_errorMessage</div>
        </div>
    </div>
}
else
{
    <div class="cm-movie-grid">
        @foreach (var movie in FilteredMovies)
        {
            <div class="cm-movie-card">
                <NavLink href="@($"/movie/{movie.Id}")" style="text-decoration:none;color:inherit">
                    <div class="cm-poster-wrapper">
                        @if (movie.HasPoster)
                        {
                            <img class="cm-poster-img"
                                 src="@($"https://localhost:7028/api/movies/{movie.Id}/poster")"
                                 alt="@movie.Title" />
                        }
                        else
                        {
                            <h2>Постер</h2>
                        }
                    </div>
                    <h3>@movie.Title</h3>
                    <p>@movie.Genre • @movie.AgeRating</p>
                </NavLink>
            </div>
        }
    </div>
}

@code {
    private bool _isLoading = true;
    private string? _errorMessage;
    private IReadOnlyList<MovieDto> _movies = [];
    private FilterKey _activeFilter = FilterKey.All;

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _movies = await Api.GetMoviesAsync();
        }
        catch (Exception ex)
        {
            _errorMessage = ex.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private IEnumerable<MovieDto> FilteredMovies
    {
        get
        {
            var released = _movies.Where(m => !m.IsComingSoon);
            var comingSoon = _movies.Where(m => m.IsComingSoon);

            return _activeFilter switch
            {
                FilterKey.All => released,
                FilterKey.Soon => comingSoon,
                FilterKey.Fantasy => released.Where(m => ContainsGenre(m, "фантаст")),
                FilterKey.Action => released.Where(m => ContainsGenre(m, "боевик")),
                _ => released
            };
        }
    }

    private void SetFilter(FilterKey filter) => _activeFilter = filter;

    private string GetFilterBtnCss(FilterKey filter)
        => $"cm-filter-btn{(filter == _activeFilter ? " active" : "")}";

    private static bool ContainsGenre(MovieDto movie, string needle)
        => (movie.Genre ?? string.Empty).Contains(needle, StringComparison.OrdinalIgnoreCase);

    private enum FilterKey
    {
        All,
        Soon,
        Fantasy,
        Action
    }
}
