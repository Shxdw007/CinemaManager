<Window x:Class="CinemaManager.AddMovieWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Добавление фильма" Height="600" Width="800"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" FontFamily="Segoe UI"
        WindowStyle="None" ResizeMode="NoResize" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid Margin="30">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Button Grid.Row="0" Content="← Назад в меню" Click="BtnBack_Click"
                Height="32" Padding="12,0" Margin="0,0,0,20"
                HorizontalAlignment="Left"
                Background="#3E3E42" Foreground="White" BorderThickness="0"/>

        <Grid Grid.Row="1">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,30,0">
            <Border Width="220" Height="320" Background="#2D2D30" BorderBrush="#3F3F46" BorderThickness="1" Margin="0,0,0,15">
                <Grid>
                    <Image x:Name="PosterPreview" Stretch="UniformToFill" />
                    <TextBlock x:Name="PosterPlaceholder"
                               Text="[ Превью постера ]"
                               Foreground="#AAAAAA"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Grid>
            </Border>
            <Button Content="Загрузить изображение"
                    Height="35"
                    Background="#333337"
                    Foreground="White"
                    BorderThickness="0"
                    Click="BtnLoadImage_Click"/>
        </StackPanel>

        <StackPanel Grid.Column="1">
            <TextBlock Text="Новый фильм" Foreground="White" FontSize="26" FontWeight="SemiBold" Margin="0,0,0,25"/>

            <TextBlock Text="Название фильма" Foreground="#CCCCCC" Margin="0,0,0,5"/>
            <TextBox x:Name="TitleTextBox" Height="35" Background="#2D2D30" Foreground="White" BorderThickness="0" Padding="10,5" Margin="0,0,0,15"/>

            <Grid Margin="0,0,0,15">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="20"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <StackPanel Grid.Column="0">
                    <TextBlock Text="Жанр" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <ComboBox x:Name="GenreComboBox" Height="35" Background="#2D2D30" Foreground="Black" BorderThickness="0" SelectedIndex="0">
                        <ComboBoxItem Content="Фантастика"/>
                        <ComboBoxItem Content="Боевик"/>
                        <ComboBoxItem Content="Драма"/>
                        <ComboBoxItem Content="Комедия"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Grid.Column="2">
                    <TextBlock Text="Возрастной рейтинг" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <ComboBox x:Name="AgeRatingComboBox" Height="35" Background="#2D2D30" Foreground="Black" BorderThickness="0" SelectedIndex="2">
                        <ComboBoxItem Content="6+"/>
                        <ComboBoxItem Content="12+"/>
                        <ComboBoxItem Content="16+"/>
                        <ComboBoxItem Content="18+"/>
                    </ComboBox>
                </StackPanel>
            </Grid>

            <TextBlock Text="Длительность (мин)" Foreground="#CCCCCC" Margin="0,0,0,5"/>
            <TextBox x:Name="DurationTextBox" Height="35" Background="#2D2D30" Foreground="White" BorderThickness="0" Padding="10,5" Margin="0,0,0,15"/>

            <TextBlock Text="Описание" Foreground="#CCCCCC" Margin="0,0,0,5"/>
            <TextBox x:Name="DescriptionTextBox" Height="100" Background="#2D2D30" Foreground="White" BorderThickness="0" Padding="10" TextWrapping="Wrap" AcceptsReturn="True"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
                <Button Content="Отмена" Click="BtnCancel_Click" Width="100" Height="35" Background="#333337" Foreground="White" BorderThickness="0" Margin="0,0,10,0"/>
                <Button Content="Сохранить" Click="BtnSave_Click" Width="120" Height="35" Background="#007ACC" Foreground="White" BorderThickness="0" FontWeight="SemiBold"/>
            </StackPanel>
        </StackPanel>
        </Grid>
    </Grid>
</Window>