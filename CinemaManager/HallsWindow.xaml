<Window x:Class="CinemaManager.HallsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление залами" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" FontFamily="Segoe UI"
        WindowStyle="None" ResizeMode="NoResize" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Назад в меню" Click="BtnBack_Click"
                    Height="32" Padding="12,0" Margin="0,0,15,0"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>

            <TextBlock Grid.Column="1" Text="Конфигурация залов" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
        </Grid>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="300"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2D2D30" Padding="20" Margin="0,0,20,0" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Добавить новый зал" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,20"/>

                    <TextBlock Text="Название / Номер" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <TextBox x:Name="HallNameTextBox" Height="35" Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#3F3F46" Padding="10,5" Margin="0,0,0,15"/>

                    <TextBlock Text="Тип зала" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <ComboBox x:Name="HallTypeComboBox" Height="35" Background="#1E1E1E" Foreground="Black" BorderThickness="0" SelectedIndex="0" Margin="0,0,0,15">
                        <ComboBoxItem Content="Стандарт (2D)"/>
                        <ComboBoxItem Content="IMAX (3D)"/>
                        <ComboBoxItem Content="VIP Зал"/>
                    </ComboBox>

                    <Grid Margin="0,0,0,20">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="15"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <StackPanel Grid.Column="0">
                            <TextBlock Text="Рядов" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                            <TextBox x:Name="RowsCountTextBox" Height="35" Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#3F3F46" Padding="10,5" Text="10"/>
                        </StackPanel>

                        <StackPanel Grid.Column="2">
                            <TextBlock Text="Мест в ряду" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                            <TextBox x:Name="SeatsPerRowTextBox" Height="35" Background="#1E1E1E" Foreground="White" BorderThickness="1" BorderBrush="#3F3F46" Padding="10,5" Text="15"/>
                        </StackPanel>
                    </Grid>

                    <Button Content="Сохранить зал" Height="40" Background="#007ACC" Foreground="White" FontSize="16" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="BtnSaveHall_Click"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="Gray" Padding="20" CornerRadius="8">
                <StackPanel>
                    <TextBlock Text="Список залов кинотеатра" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                    <DataGrid x:Name="HallsGrid" Background="Transparent" BorderThickness="0" HeadersVisibility="Column" AutoGenerateColumns="False" IsReadOnly="True" RowBackground="White" AlternatingRowBackground="White" Foreground="Black" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#3E3E42">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Название" Width="150" Binding="{Binding Name}"/>
                            <DataGridTextColumn Header="Тип" Width="120" Binding="{Binding Type}"/>
                            <DataGridTextColumn Header="Вместимость" Width="120" Binding="{Binding Capacity}"/>
                            <DataGridTemplateColumn Header="Действия" Width="*">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <StackPanel Orientation="Horizontal">
                                            <Button Content="✎"
                                                    Width="34"
                                                    Height="28"
                                                    Margin="0,0,8,0"
                                                    Background="#3E3E42"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Click="BtnEditHall_Click"
                                                    Tag="{Binding}"/>
                                            <Button Content="🗑"
                                                    Width="34"
                                                    Height="28"
                                                    Background="#8A1F1F"
                                                    Foreground="White"
                                                    BorderThickness="0"
                                                    Click="BtnDeleteHall_Click"
                                                    Tag="{Binding}"/>
                                        </StackPanel>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>