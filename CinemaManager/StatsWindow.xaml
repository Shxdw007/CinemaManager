<Window x:Class="CinemaManager.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" FontFamily="Segoe UI"
        WindowStyle="None" ResizeMode="NoResize" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Назад в меню" Click="BtnBack_Click"
                    Height="32" Padding="12,0" Margin="0,0,15,0"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>

            <TextBlock Grid.Column="1" Text="Аналитика продаж" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,25">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2D2D30" Margin="0,0,10,0" Padding="20" BorderBrush="#007ACC" BorderThickness="0,0,0,3">
                <StackPanel>
                    <TextBlock Text="Выручка сегодня" Foreground="#AAAAAA" FontSize="14"/>
                    <TextBlock Text="145 800 ₽" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                    <TextBlock Text="+12% со вчера" Foreground="#4CAF50" FontSize="12" Margin="0,5,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#2D2D30" Margin="10,0,10,0" Padding="20" BorderBrush="#007ACC" BorderThickness="0,0,0,3">
                <StackPanel>
                    <TextBlock Text="Продано билетов" Foreground="#AAAAAA" FontSize="14"/>
                    <TextBlock Text="342" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#2D2D30" Margin="10,0,0,0" Padding="20" BorderBrush="#007ACC" BorderThickness="0,0,0,3">
                <StackPanel>
                    <TextBlock Text="Средняя заполняемость" Foreground="#AAAAAA" FontSize="14"/>
                    <TextBlock Text="78%" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#2D2D30" Padding="20">
            <StackPanel>
                <TextBlock Text="Топ фильмов в прокате" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,15"/>
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="1." Foreground="#007ACC" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Дюна: Часть вторая" Foreground="White"/>
                    <TextBlock Grid.Column="2" Text="85 400 ₽" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                </Grid>
                <Grid Margin="0,5">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="30"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="100"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0" Text="2." Foreground="#007ACC" FontWeight="Bold"/>
                    <TextBlock Grid.Column="1" Text="Мастер и Маргарита" Foreground="White"/>
                    <TextBlock Grid.Column="2" Text="42 100 ₽" Foreground="#4CAF50" HorizontalAlignment="Right"/>
                </Grid>
            </StackPanel>
        </Border>
    </Grid>
</Window>