<Window x:Class="CinemaManager.StatsWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Статистика" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" FontFamily="Segoe UI"
        WindowStyle="None" ResizeMode="NoResize" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid Margin="25">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Назад в меню" Click="BtnBack_Click"
                    Height="32" Padding="12,0" Margin="0,0,15,0"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>

            <TextBlock Grid.Column="1" Text="Аналитика продаж" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
        </Grid>

        <Grid Grid.Row="1" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Background="#2D2D30" Margin="0,0,10,0" Padding="20" BorderBrush="#007ACC" BorderThickness="0,0,0,3">
                <StackPanel>
                    <TextBlock Text="Фильмов" Foreground="#AAAAAA" FontSize="14"/>
                    <TextBlock x:Name="MoviesCountText" Text="—" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="1" Background="#2D2D30" Margin="10,0,10,0" Padding="20" BorderBrush="#007ACC" BorderThickness="0,0,0,3">
                <StackPanel>
                    <TextBlock Text="Залов" Foreground="#AAAAAA" FontSize="14"/>
                    <TextBlock x:Name="HallsCountText" Text="—" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="2" Background="#2D2D30" Margin="10,0,10,0" Padding="20" BorderBrush="#007ACC" BorderThickness="0,0,0,3">
                <StackPanel>
                    <TextBlock Text="Сеансов" Foreground="#AAAAAA" FontSize="14"/>
                    <TextBlock x:Name="SessionsCountText" Text="—" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>

            <Border Grid.Column="3" Background="#2D2D30" Margin="10,0,0,0" Padding="20" BorderBrush="#007ACC" BorderThickness="0,0,0,3">
                <StackPanel>
                    <TextBlock Text="Билетов" Foreground="#AAAAAA" FontSize="14"/>
                    <TextBlock x:Name="TicketsCountText" Text="—" Foreground="White" FontSize="32" FontWeight="Bold" Margin="0,10,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2" Background="#2D2D30" Padding="20">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <TextBlock Grid.Row="0" Text="Доходы по фильмам" Foreground="White" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="С:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="StartDatePicker" Width="130" Height="28" Margin="0,0,15,0"/>
                    <TextBlock Text="По:" Foreground="#AAAAAA" VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <DatePicker x:Name="EndDatePicker" Width="130" Height="28" Margin="0,0,15,0"/>
                    <Button Content="Показать" Width="110" Height="28" Background="#007ACC" Foreground="White" BorderThickness="0" Click="BtnShow_Click"/>
                </StackPanel>

                <TextBlock Grid.Row="2" x:Name="TotalIncomeText" Text="Общий доход: —" Foreground="White" FontSize="16" Margin="0,0,0,10"/>

                <DataGrid Grid.Row="3" x:Name="MovieSalesGrid"
                          Background="Transparent"
                          BorderThickness="0"
                          HeadersVisibility="Column"
                          AutoGenerateColumns="False"
                          IsReadOnly="True"
                          Foreground="White"
                          RowBackground="#2D2D30"
                          AlternatingRowBackground="#333337"
                          GridLinesVisibility="Horizontal"
                          HorizontalGridLinesBrush="#3F3F46">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Фильм" Width="*" Binding="{Binding MovieTitle}"/>
                        <DataGridTextColumn Header="Продано" Width="120" Binding="{Binding TicketsSold}"/>
                        <DataGridTextColumn Header="Доход" Width="160" Binding="{Binding Income}"/>
                    </DataGrid.Columns>
                </DataGrid>

                <TextBlock Grid.Row="3" x:Name="StatsStatusText" Text="Загрузка…" Foreground="#AAAAAA" VerticalAlignment="Bottom" Margin="0,10,0,0"/>
            </Grid>
        </Border>
    </Grid>
</Window>