<Window x:Class="CinemaManager.ScheduleWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Управление расписанием" Height="700" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" FontFamily="Segoe UI"
        WindowStyle="None" ResizeMode="NoResize" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,20">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <Button Grid.Column="0" Content="← Назад в меню" Click="BtnBack_Click"
                    Height="32" Padding="12,0" Margin="0,0,15,0"
                    Background="#3E3E42" Foreground="White" BorderThickness="0"/>

            <TextBlock Grid.Column="1" Text="Сетка сеансов" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
        </Grid>

        <Border Grid.Row="1" Background="#2D2D30" Padding="20" Margin="0,0,0,20">
            <StackPanel Orientation="Horizontal">
                <StackPanel Margin="0,0,15,0" Width="250">
                    <TextBlock Text="Фильм" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <ComboBox x:Name="MovieComboBox" Height="30" DisplayMemberPath="Title" SelectedValuePath="Id"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0" Width="120">
                    <TextBlock Text="Зал" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <ComboBox x:Name="HallComboBox" Height="30" DisplayMemberPath="Name" SelectedValuePath="Id"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0" Width="120">
                    <TextBlock Text="Дата" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <DatePicker x:Name="DatePicker" Height="30"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0" Width="100">
                    <TextBlock Text="Время" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <TextBox x:Name="TimeTextBox" Height="30" Text="18:30" Padding="5" VerticalContentAlignment="Center"/>
                </StackPanel>

                <StackPanel Margin="0,0,15,0" Width="100">
                    <TextBlock Text="Цена" Foreground="#CCCCCC" Margin="0,0,0,5"/>
                    <TextBox x:Name="PriceTextBox" Height="30" Text="350" Padding="5" VerticalContentAlignment="Center"/>
                </StackPanel>

                <Button Content="+ Добавить" Width="120" Height="30" Background="#007ACC" Foreground="White" BorderThickness="0" Margin="0,21,0,0" FontWeight="SemiBold" Click="BtnAddSession_Click"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="#2D2D30">
            <DataGrid x:Name="SessionsGrid" Background="Transparent" BorderThickness="0" HeadersVisibility="Column" AutoGenerateColumns="False" IsReadOnly="True" Foreground="White" RowBackground="#2D2D30" AlternatingRowBackground="#333337" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#3F3F46">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Время" Width="100" Binding="{Binding StartTime, StringFormat={}{0:HH\\:mm}}"/>
                    <DataGridTextColumn Header="Фильм" Width="300" Binding="{Binding MovieTitle}"/>
                    <DataGridTextColumn Header="Зал" Width="150" Binding="{Binding HallName}"/>
                    <DataGridTextColumn Header="Окончание (с уборкой)" Width="180" Binding="{Binding EndTime, StringFormat={}{0:HH\\:mm}}"/>
                    <DataGridTextColumn Header="Цена" Width="100" Binding="{Binding TicketPrice}"/>
                </DataGrid.Columns>
            </DataGrid>
        </Border>
    </Grid>
</Window>