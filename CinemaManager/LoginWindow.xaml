<Window x:Class="CinemaManager.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Авторизация" Height="450" Width="400"
        WindowStartupLocation="CenterScreen" Background="#1E1E1E" FontFamily="Segoe UI"
        WindowStyle="None" ResizeMode="NoResize" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Border Background="#2D2D30" CornerRadius="10" Margin="30" Padding="30">
        <StackPanel VerticalAlignment="Center">
            <TextBlock Text="CINEMA MANAGER" Foreground="#007ACC" FontSize="24" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,10"/>
            <TextBlock Text="Панель администратора" Foreground="#AAAAAA" FontSize="14" HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <TextBlock Text="Логин" Foreground="#E0E0E0" Margin="0,0,0,5"/>
            <TextBox x:Name="EmailTextBox" Height="35" Background="#1E1E1E" Foreground="White" BorderBrush="#3F3F46" BorderThickness="1" Padding="10,5" Margin="0,0,0,15"/>

            <TextBlock Text="Пароль" Foreground="#E0E0E0" Margin="0,0,0,5"/>
            <PasswordBox x:Name="PasswordBox" Height="35" Background="#1E1E1E" Foreground="White" BorderBrush="#3F3F46" BorderThickness="1" Padding="10,5" Margin="0,0,0,30"/>

            <Button Content="Войти в систему" Height="40" Background="#007ACC" Foreground="White" FontSize="16" FontWeight="SemiBold" BorderThickness="0" Cursor="Hand" Click="BtnLogin_Click"/>

            <Button Content="✖ Закрыть приложение" Height="35" Background="#3E3E42" Foreground="White"
                    FontSize="14" BorderThickness="0" Cursor="Hand" Margin="0,15,0,0"
                    Click="BtnExitApp_Click"/>
        </StackPanel>
    </Border>
</Window>