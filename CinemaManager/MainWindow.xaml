<Window x:Class="CinemaManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="CinemaManager - Панель администратора" Height="720" Width="1080"
        WindowStartupLocation="CenterScreen" Background="#202020" FontFamily="Segoe UI"
        WindowStyle="None" ResizeMode="NoResize" MouseLeftButtonDown="Window_MouseLeftButtonDown">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#2D2D30" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <TextBlock Text="CinemaManager" Foreground="White" FontSize="22" FontWeight="Bold" Margin="0,10,0,30" HorizontalAlignment="Center"/>

                <StackPanel Grid.Row="1">
                    <Button Content="🎬 Фильмы" Background="#3E3E42" Foreground="White" Height="40" Margin="0,5" BorderThickness="0" FontSize="16" HorizontalContentAlignment="Left" Padding="15,0"/>
                    <Button Content="📅 Сеансы" Click="BtnSchedule_Click" Background="Transparent" Foreground="#CCCCCC" Height="40" Margin="0,5" BorderThickness="0" FontSize="16" HorizontalContentAlignment="Left" Padding="15,0"/>
                    <Button Content="💺 Залы" Background="Transparent" Foreground="#CCCCCC" Height="40" Margin="0,5" BorderThickness="0" FontSize="16" HorizontalContentAlignment="Left" Padding="15,0" Click="Button_Click"/>
                    <Button Content="📊 Статистика" Click="BtnStats_Click"
                            Background="Transparent" Foreground="#CCCCCC" Height="40" Margin="0,5"
                            BorderThickness="0" FontSize="16" HorizontalContentAlignment="Left" Padding="15,0"/>
                </StackPanel>

                <Button Grid.Row="2" Content="✖ Закрыть приложение" Click="BtnExitApp_Click"
                        Background="#3E3E42" Foreground="White" Height="40" Margin="0,20,0,0"
                        BorderThickness="0" FontSize="14" HorizontalContentAlignment="Center"/>
            </Grid>
        </Border>

        <Grid Grid.Column="1" Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="Управление фильмами" Foreground="White" FontSize="28" FontWeight="SemiBold"/>
                <Button Content="+ Добавить фильм" Click="BtnAddMovie_Click" HorizontalAlignment="Right" Width="150" Height="35" Background="#007ACC" Foreground="White" BorderThickness="0" FontSize="14"/>
            </Grid>

            <DataGrid x:Name="MoviesGrid" Grid.Row="1" Background="#2D2D30" BorderThickness="0" HeadersVisibility="Column" AutoGenerateColumns="False" IsReadOnly="True" RowBackground="Gray" AlternatingRowBackground="White" Foreground="Black" GridLinesVisibility="Horizontal" HorizontalGridLinesBrush="#3E3E42">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Width="50" Binding="{Binding Id}"/>
                    <DataGridTextColumn Header="Название" Width="300" Binding="{Binding Title}"/>
                    <DataGridTextColumn Header="Жанр" Width="150" Binding="{Binding Genre}"/>
                    <DataGridTextColumn Header="Длительность" Width="120" Binding="{Binding Duration}"/>
                    <DataGridTextColumn Header="Рейтинг" Width="80" Binding="{Binding AgeRating}"/>
                    <DataGridTemplateColumn Header="Действия" Width="*">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                                    <Button Content="✎ Изменить"
                                            Margin="0,0,10,0"
                                            Padding="10,4"
                                            Background="#3E3E42"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Click="BtnEditMovie_Click"
                                            Tag="{Binding}"/>
                                    <Button Content="🗑 Удалить"
                                            Padding="10,4"
                                            Background="#8A1F1F"
                                            Foreground="White"
                                            BorderThickness="0"
                                            Click="BtnDeleteMovie_Click"
                                            Tag="{Binding}"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>
    </Grid>
</Window>